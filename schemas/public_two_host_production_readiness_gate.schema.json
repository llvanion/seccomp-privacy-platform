{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "public_two_host_production_readiness_gate/v1",
  "title": "Public two-host production readiness gate",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "status",
    "repo_side_status",
    "live_status",
    "repo_side_checks",
    "live_checks",
    "verifier_view",
    "repo_side_boundary",
    "live_boundary",
    "artifacts"
  ],
  "properties": {
    "schema": { "const": "public_two_host_production_readiness_gate/v1" },
    "generated_at_utc": { "type": "string", "minLength": 1 },
    "status": { "enum": ["ok", "fail"] },
    "repo_side_status": { "enum": ["ok", "fail"] },
    "live_status": { "enum": ["ok", "fail", "skipped"] },
    "repo_side_checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/check" }
    },
    "live_checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/check" }
    },
    "verifier_view": {
      "type": "object",
      "required": [
        "claim",
        "required_live_artifacts",
        "current_live_blockers",
        "attacker_surfaces",
        "artifact_index"
      ],
      "properties": {
        "claim": { "type": "string", "minLength": 1 },
        "required_live_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "current_live_blockers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "attacker_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "artifact_index": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/artifact" }
        }
      },
      "additionalProperties": false
    },
    "repo_side_boundary": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "live_boundary": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/artifact" }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "required": ["name", "status", "expected", "actual"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "status": { "enum": ["ok", "fail", "skipped"] },
        "expected": {},
        "actual": {},
        "missing_prerequisites": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "schema": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
