{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pjc_benchmark/v1",
  "title": "Benchmark report for the standalone PJC runner",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "repo_root",
    "pjc_bin_dir",
    "expected_result",
    "iterations",
    "modes"
  ],
  "properties": {
    "schema": {
      "const": "pjc_benchmark/v1"
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    },
    "pjc_bin_dir": {
      "type": "string",
      "minLength": 1
    },
    "expected_result": {
      "type": "object",
      "required": [
        "intersection_size",
        "intersection_sum"
      ],
      "properties": {
        "intersection_size": {
          "type": "integer",
          "minimum": 0
        },
        "intersection_sum": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "iterations": {
      "type": "integer",
      "minimum": 1
    },
    "modes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "mode",
          "command",
          "input_fixture",
          "summary",
          "results"
        ],
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "checked_in_sse_demo_job",
              "generated_scale_csv"
            ]
          },
          "command": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "input_fixture": {
            "type": "object",
            "required": [
              "server_csv",
              "client_csv"
            ],
            "properties": {
              "server_csv": {
                "type": "string",
                "minLength": 1
              },
              "client_csv": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          },
          "scale": {
            "type": "object",
            "required": [
              "source",
              "server_items",
              "client_items",
              "overlap_count",
              "overlap_ratio",
              "expected_intersection_size",
              "expected_intersection_sum"
            ],
            "properties": {
              "source": {
                "type": "string",
                "enum": [
                  "checked_in_fixture",
                  "generated_csv"
                ]
              },
              "server_items": {
                "type": "integer",
                "minimum": 0
              },
              "client_items": {
                "type": "integer",
                "minimum": 0
              },
              "overlap_count": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0
              },
              "overlap_ratio": {
                "type": [
                  "number",
                  "null"
                ],
                "minimum": 0,
                "maximum": 1
              },
              "expected_intersection_size": {
                "type": "integer",
                "minimum": 0
              },
              "expected_intersection_sum": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          },
          "summary": {
            "type": "object",
            "required": [
              "iterations",
              "successful_iterations",
              "failed_iterations",
              "duration_ms"
            ],
            "properties": {
              "iterations": {
                "type": "integer",
                "minimum": 0
              },
              "successful_iterations": {
                "type": "integer",
                "minimum": 0
              },
              "failed_iterations": {
                "type": "integer",
                "minimum": 0
              },
              "duration_ms": {
                "type": "object",
                "required": [
                  "min",
                  "mean",
                  "p50",
                  "p95",
                  "max"
                ],
                "properties": {
                  "min": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "mean": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "p50": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "p95": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "max": {
                    "type": [
                      "number",
                      "null"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "duration_ms",
                "exit_code",
                "timed_out",
                "stderr_tail",
                "stdout_tail",
                "intersection_size",
                "intersection_sum",
                "result_file"
              ],
              "properties": {
                "duration_ms": {
                  "type": "number",
                  "minimum": 0
                },
                "exit_code": {
                  "type": "integer"
                },
                "timed_out": {
                  "type": "boolean"
                },
                "stderr_tail": {
                  "type": "string"
                },
                "stdout_tail": {
                  "type": "string"
                },
                "intersection_size": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "intersection_sum": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "result_file": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "peak_rss_kb": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
