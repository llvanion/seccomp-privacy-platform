{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sse_record_recovery_service_audit/v1",
  "title": "SSE record recovery service audit JSONL record",
  "type": "object",
  "required": [
    "schema",
    "ts_utc",
    "event",
    "service_id",
    "tenant_id",
    "dataset_id",
    "caller",
    "role",
    "auth_mode",
    "transport",
    "socket_path",
    "decision",
    "reason_code",
    "reason"
  ],
  "properties": {
    "schema": {
      "const": "sse_record_recovery_service_audit/v1"
    },
    "ts_utc": {
      "type": "string",
      "format": "date-time"
    },
    "event": {
      "const": "record_recovery_service_request"
    },
    "service_id": {
      "type": ["string", "null"]
    },
    "tenant_id": {
      "type": ["string", "null"]
    },
    "dataset_id": {
      "type": ["string", "null"]
    },
    "caller": {
      "type": "string"
    },
    "correlation_id": {
      "type": ["string", "null"]
    },
    "job_id": {
      "type": ["string", "null"]
    },
    "role": {
      "enum": ["server", "client", "unknown"]
    },
    "auth_mode": {
      "enum": ["env_token", "socket_acl_only"]
    },
    "transport": {
      "enum": ["unix_socket", "http"]
    },
    "socket_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "endpoint_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "authz_policy_config": {
      "type": ["string", "null"]
    },
    "record_store_file": {
      "type": ["string", "null"]
    },
    "record_store_sha256": {
      "type": ["string", "null"]
    },
    "output_file": {
      "type": ["string", "null"]
    },
    "output_file_type": {
      "enum": ["file", "fifo", "other", "missing"]
    },
    "output_sha256": {
      "type": ["string", "null"]
    },
    "join_key_field": {
      "type": ["string", "null"]
    },
    "value_field": {
      "type": ["string", "null"]
    },
    "candidate_count": {
      "type": ["integer", "null"]
    },
    "filters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "value_sha256"],
        "properties": {
          "field": {
            "type": "string"
          },
          "value_sha256": {
            "type": "string"
          }
        }
      }
    },
    "request_timestamp_utc": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "request_signature_verified": {
      "type": ["boolean", "null"]
    },
    "signature_algorithm": {
      "type": ["string", "null"]
    },
    "input_rows": {
      "type": ["integer", "null"]
    },
    "output_rows": {
      "type": ["integer", "null"]
    },
    "duration_ms": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "decision": {
      "enum": ["allow", "deny"]
    },
    "reason_code": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    }
  }
}
