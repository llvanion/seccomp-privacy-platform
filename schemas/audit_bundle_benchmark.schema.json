{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "audit_bundle_benchmark/v1",
  "title": "Benchmark report for audit bundle archive and verification entrypoints",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "repo_root",
    "fixture_profile",
    "job_id",
    "iterations",
    "modes"
  ],
  "properties": {
    "schema": {
      "const": "audit_bundle_benchmark/v1"
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    },
    "fixture_profile": {
      "type": "string",
      "const": "synthetic_audit_bundle_v1"
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "iterations": {
      "type": "integer",
      "minimum": 1
    },
    "modes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "mode",
          "command",
          "summary",
          "results"
        ],
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "archive_cli",
              "verify_direct_cli",
              "verify_archive_index_cli",
              "verify_archive_index_restore_cli"
            ]
          },
          "command": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "summary": {
            "type": "object",
            "required": [
              "iterations",
              "successful_iterations",
              "failed_iterations",
              "duration_ms"
            ],
            "properties": {
              "iterations": {
                "type": "integer",
                "minimum": 0
              },
              "successful_iterations": {
                "type": "integer",
                "minimum": 0
              },
              "failed_iterations": {
                "type": "integer",
                "minimum": 0
              },
              "duration_ms": {
                "type": "object",
                "required": [
                  "min",
                  "mean",
                  "p50",
                  "p95",
                  "max"
                ],
                "properties": {
                  "min": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "mean": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "p50": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "p95": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "max": {
                    "type": [
                      "number",
                      "null"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "duration_ms",
                "exit_code",
                "timed_out",
                "stderr_tail",
                "stdout_tail",
                "verified",
                "signature_verified",
                "archive_index_verified",
                "restored",
                "archive_index_path",
                "anchor_log_verified",
                "anchor_signature_verified",
                "anchor_log_path"
              ],
              "properties": {
                "duration_ms": {
                  "type": "number",
                  "minimum": 0
                },
                "exit_code": {
                  "type": "integer"
                },
                "timed_out": {
                  "type": "boolean"
                },
                "stderr_tail": {
                  "type": "string"
                },
                "stdout_tail": {
                  "type": "string"
                },
                "verified": {
                  "type": "boolean"
                },
                "signature_verified": {
                  "type": [
                    "boolean",
                    "null"
                  ]
                },
                "archive_index_verified": {
                  "type": "boolean"
                },
                "restored": {
                  "type": "boolean"
                },
                "archive_index_path": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "anchor_log_verified": {
                  "type": "boolean"
                },
                "anchor_signature_verified": {
                  "type": [
                    "boolean",
                    "null"
                  ]
                },
                "anchor_log_path": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
