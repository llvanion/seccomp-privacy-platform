{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "production_security_closure_gate/v1",
  "title": "Production security closure gate",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "status",
    "repo_side_status",
    "live_status",
    "summary",
    "modules",
    "repo_side_boundary",
    "live_boundary",
    "artifacts"
  ],
  "properties": {
    "schema": { "const": "production_security_closure_gate/v1" },
    "generated_at_utc": { "type": "string", "minLength": 1 },
    "status": { "enum": ["ok", "fail"] },
    "repo_side_status": { "enum": ["ok", "fail"] },
    "live_status": { "enum": ["ok", "fail", "skipped"] },
    "summary": {
      "type": "object",
      "required": [
        "module_count",
        "repo_side_ok_count",
        "repo_side_fail_count",
        "live_ok_count",
        "live_fail_count",
        "live_skipped_count",
        "live_foundation_ok_count",
        "live_foundation_fail_count",
        "live_foundation_skipped_count"
      ],
      "properties": {
        "module_count": { "type": "integer", "minimum": 1 },
        "repo_side_ok_count": { "type": "integer", "minimum": 0 },
        "repo_side_fail_count": { "type": "integer", "minimum": 0 },
        "live_ok_count": { "type": "integer", "minimum": 0 },
        "live_fail_count": { "type": "integer", "minimum": 0 },
        "live_skipped_count": { "type": "integer", "minimum": 0 },
        "live_foundation_ok_count": { "type": "integer", "minimum": 0 },
        "live_foundation_fail_count": { "type": "integer", "minimum": 0 },
        "live_foundation_skipped_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "schema", "path", "status", "repo_side_status", "live_status", "live_foundation_status"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "schema": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "status": { "enum": ["ok", "fail"] },
          "repo_side_status": { "enum": ["ok", "fail"] },
          "live_status": { "enum": ["ok", "fail", "skipped"] },
          "live_foundation_status": { "enum": ["ok", "fail", "skipped"] }
        },
        "additionalProperties": false
      }
    },
    "repo_side_boundary": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "live_boundary": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "remaining_live_blockers_report": {},
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "schema"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "schema": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
