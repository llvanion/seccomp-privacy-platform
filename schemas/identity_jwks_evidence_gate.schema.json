{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "identity_jwks_evidence_gate/v1",
  "title": "JWKS / OIDC identity evidence gate",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "status",
    "checks",
    "repo_side_boundary",
    "artifacts"
  ],
  "properties": {
    "schema": { "const": "identity_jwks_evidence_gate/v1" },
    "generated_at_utc": { "type": "string", "minLength": 1 },
    "status": { "enum": ["ok", "fail"] },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "status", "expected", "actual"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "enum": ["ok", "fail"] },
          "expected": {},
          "actual": {}
        },
        "additionalProperties": false
      }
    },
    "repo_side_boundary": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "schema": { "type": "string", "minLength": 1 },
          "note": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
