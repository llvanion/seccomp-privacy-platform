{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "policy_drift/v1",
  "type": "object",
  "required": [
    "schema", "generated_at_utc", "db_path", "mode", "summary", "findings", "repair_actions"
  ],
  "properties": {
    "schema": { "type": "string", "const": "policy_drift/v1" },
    "generated_at_utc": { "type": "string" },
    "db_path": { "type": "string" },
    "mode": { "type": "string", "enum": ["dry_run", "repair"] },
    "summary": {
      "type": "object",
      "required": [
        "registered_policy_count", "total_findings",
        "findings_by_kind", "repair_action_count", "status"
      ],
      "properties": {
        "registered_policy_count": { "type": "integer", "minimum": 0 },
        "total_findings": { "type": "integer", "minimum": 0 },
        "findings_by_kind": { "type": "object" },
        "repair_action_count": { "type": "integer", "minimum": 0 },
        "status": { "type": "string", "enum": ["clean", "drift_detected"] }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "policy_id", "path", "detail"],
        "properties": {
          "kind": { "type": "string" },
          "policy_id": { "type": "string" },
          "path": { "type": "string" },
          "detail": { "type": "string" }
        }
      }
    },
    "repair_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action", "applied"],
        "properties": {
          "action": { "type": "string" },
          "applied": { "type": "boolean" }
        }
      }
    }
  },
  "additionalProperties": false
}
