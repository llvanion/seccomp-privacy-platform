{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pjc_two_party_evidence_merge/v1",
  "title": "PJC two-party evidence merge report",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "job_id",
    "decision",
    "reason_code",
    "party_a",
    "party_b",
    "checks",
    "findings"
  ],
  "properties": {
    "schema": { "const": "pjc_two_party_evidence_merge/v1" },
    "generated_at_utc": { "type": "string", "format": "date-time" },
    "job_id": { "type": "string", "minLength": 1 },
    "decision": { "enum": ["allow", "deny"] },
    "reason_code": {
      "enum": [
        "ok",
        "job_id_mismatch",
        "commit_mismatch",
        "input_manifest_mismatch",
        "tls_identity_mismatch",
        "ca_fingerprint_mismatch",
        "result_hash_mismatch",
        "policy_decision_mismatch",
        "audit_chain_hash_mismatch",
        "missing_party_artifacts",
        "config_error"
      ]
    },
    "reason": { "type": ["string", "null"] },
    "party_a": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": { "type": "string" },
        "job_id": { "type": ["string", "null"] },
        "commit": { "type": ["string", "null"] },
        "input_commitment_sha256": { "type": ["string", "null"] },
        "tls_identity": { "type": ["string", "null"] },
        "ca_fingerprint_sha256": { "type": ["string", "null"] },
        "result_sha256": { "type": ["string", "null"] },
        "policy_decision": { "type": ["string", "null"] },
        "audit_chain_sha256": { "type": ["string", "null"] },
        "missing_files": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "party_b": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": { "type": "string" },
        "job_id": { "type": ["string", "null"] },
        "commit": { "type": ["string", "null"] },
        "input_commitment_sha256": { "type": ["string", "null"] },
        "tls_identity": { "type": ["string", "null"] },
        "ca_fingerprint_sha256": { "type": ["string", "null"] },
        "result_sha256": { "type": ["string", "null"] },
        "policy_decision": { "type": ["string", "null"] },
        "audit_chain_sha256": { "type": ["string", "null"] },
        "missing_files": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "object",
      "required": [
        "job_id_match",
        "commit_match",
        "input_commitment_match",
        "tls_identity_match",
        "ca_fingerprint_match",
        "result_hash_match",
        "policy_decision_match",
        "audit_chain_match"
      ],
      "properties": {
        "job_id_match": { "enum": ["match", "mismatch", "missing"] },
        "commit_match": { "enum": ["match", "mismatch", "missing"] },
        "input_commitment_match": { "enum": ["match", "mismatch", "missing"] },
        "tls_identity_match": { "enum": ["match", "mismatch", "missing"] },
        "ca_fingerprint_match": { "enum": ["match", "mismatch", "missing"] },
        "result_hash_match": { "enum": ["match", "mismatch", "missing"] },
        "policy_decision_match": { "enum": ["match", "mismatch", "missing"] },
        "audit_chain_match": { "enum": ["match", "mismatch", "missing"] }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "message"],
        "properties": {
          "kind": { "type": "string" },
          "message": { "type": "string", "minLength": 1 },
          "expected": {},
          "actual": {}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
