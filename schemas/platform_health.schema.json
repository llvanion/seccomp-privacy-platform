{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "platform_health/v1",
  "title": "Read-only platform health summary",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "repo_root",
    "summary",
    "checks"
  ],
  "properties": {
    "schema": {
      "const": "platform_health/v1"
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "object",
      "required": [
        "ok",
        "warn",
        "error",
        "status"
      ],
      "properties": {
        "ok": {
          "type": "integer",
          "minimum": 0
        },
        "warn": {
          "type": "integer",
          "minimum": 0
        },
        "error": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "warn",
            "error"
          ]
        }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "component",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "component": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "warn",
              "error"
            ]
          },
          "details": {
            "type": "object"
          },
          "error": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
