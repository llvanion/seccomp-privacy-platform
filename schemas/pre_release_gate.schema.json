{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pre_release_gate/v1",
  "title": "Pre-release gate consolidated check report",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "summary",
    "gates"
  ],
  "properties": {
    "schema": {
      "const": "pre_release_gate/v1"
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "object",
      "required": [
        "total",
        "passed",
        "failed",
        "status"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "enum": ["ok", "fail"]
        }
      },
      "additionalProperties": false
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "status",
          "duration_ms",
          "exit_code"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail"]
          },
          "duration_ms": {
            "type": "number",
            "minimum": 0
          },
          "exit_code": {
            "type": "integer"
          },
          "output_schema": {
            "type": ["string", "null"]
          },
          "output_schema_valid": {
            "type": ["boolean", "null"]
          },
          "stderr_tail": {
            "type": ["string", "null"]
          },
          "schema_error": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
