{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "metadata_db_failover_test/v1",
  "title": "Metadata DB failover test report (J2-b)",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "status",
    "configuration",
    "baseline_query",
    "failover_request",
    "post_failover_query",
    "data_integrity",
    "errors"
  ],
  "properties": {
    "schema": {
      "const": "metadata_db_failover_test/v1"
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["ok", "fail"]
    },
    "configuration": {
      "type": "object",
      "required": [
        "backend",
        "simulation_mode",
        "simulated_failure_count",
        "retry_attempts_allowed",
        "retry_base_delay_seconds",
        "failover_target_seconds"
      ],
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["sqlite", "postgres"]
        },
        "simulation_mode": {
          "type": "string",
          "enum": ["in_process_simulated", "operator_environment_only"]
        },
        "simulated_failure_count": {
          "type": "integer",
          "minimum": 0
        },
        "retry_attempts_allowed": {
          "type": "integer",
          "minimum": 1
        },
        "retry_base_delay_seconds": {
          "type": "number",
          "minimum": 0
        },
        "failover_target_seconds": {
          "type": "number",
          "minimum": 0
        },
        "db_path": {
          "type": ["string", "null"]
        },
        "db_dsn": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "baseline_query": {
      "type": "object",
      "required": [
        "ok",
        "duration_ms",
        "rows_returned",
        "job_id"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "rows_returned": {
          "type": "integer",
          "minimum": 0
        },
        "job_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "failover_request": {
      "type": "object",
      "required": [
        "primary_attempt_failed",
        "simulated_failure_count",
        "actual_attempts_used",
        "total_failover_duration_ms",
        "within_failover_target",
        "ok"
      ],
      "properties": {
        "primary_attempt_failed": {
          "type": "boolean"
        },
        "simulated_failure_count": {
          "type": "integer",
          "minimum": 0
        },
        "actual_attempts_used": {
          "type": "integer",
          "minimum": 0
        },
        "total_failover_duration_ms": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "within_failover_target": {
          "type": "boolean"
        },
        "ok": {
          "type": "boolean"
        },
        "failure_reason": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "post_failover_query": {
      "type": "object",
      "required": [
        "ok",
        "duration_ms",
        "rows_returned",
        "job_id",
        "data_round_trip_ok"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "rows_returned": {
          "type": "integer",
          "minimum": 0
        },
        "job_id": {
          "type": "string",
          "minLength": 1
        },
        "data_round_trip_ok": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "data_integrity": {
      "type": "object",
      "required": [
        "rows_inserted_pre_failover",
        "rows_inserted_post_failover",
        "rows_observed_post_failover",
        "no_data_lost",
        "errors"
      ],
      "properties": {
        "rows_inserted_pre_failover": {
          "type": "integer",
          "minimum": 0
        },
        "rows_inserted_post_failover": {
          "type": "integer",
          "minimum": 0
        },
        "rows_observed_post_failover": {
          "type": "integer",
          "minimum": 0
        },
        "no_data_lost": {
          "type": "boolean"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
