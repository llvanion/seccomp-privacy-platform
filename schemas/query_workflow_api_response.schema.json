{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "query_workflow_api_response/v1",
  "title": "Success envelope for the local query/workflow HTTP adapter",
  "type": "object",
  "required": [
    "schema",
    "method",
    "path",
    "result"
  ],
  "properties": {
    "schema": {
      "const": "query_workflow_api_response/v1"
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "object",
      "required": [
        "request_base_dir",
        "authenticated_identity",
        "manifest",
        "receipt",
        "status",
        "submission_manifest_path",
        "execution_receipts_path",
        "status_path",
        "exit_code"
      ],
      "properties": {
        "request_base_dir": {
          "type": "string",
          "minLength": 1
        },
        "authenticated_identity": {
          "type": ["object", "null"]
        },
        "manifest": {
          "type": "object",
          "required": [
            "schema",
            "submitted_at_utc",
            "request_file",
            "query_type",
            "workflow",
            "mode",
            "pipeline_script",
            "request_summary",
            "command",
            "exit_code"
          ],
          "properties": {
            "schema": { "const": "query_workflow_submission/v1" },
            "submitted_at_utc": { "type": "string", "minLength": 1 },
            "request_file": { "type": "string", "minLength": 1 },
            "query_type": { "type": ["string", "null"] },
            "workflow": { "type": "string", "const": "sse_bridge_pipeline" },
            "mode": { "type": "string", "enum": ["dry_run", "execute"] },
            "pipeline_script": { "type": "string", "minLength": 1 },
            "request_summary": {
              "type": "object",
              "additionalProperties": {
                "type": ["string", "array", "integer", "number", "boolean", "null"],
                "items": { "type": "string" }
              }
            },
            "command": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "exit_code": { "type": ["integer", "null"] }
          },
          "additionalProperties": false
        },
        "receipt": {
          "type": ["object", "null"],
          "required": ["schema"],
          "properties": {
            "schema": { "const": "query_workflow_receipt/v1" }
          },
          "additionalProperties": true
        },
        "status": {
          "type": ["object", "null"],
          "required": ["schema"],
          "properties": {
            "schema": { "const": "query_workflow_status/v1" }
          },
          "additionalProperties": true
        },
        "submission_manifest_path": { "type": "string", "minLength": 1 },
        "execution_receipts_path": { "type": "string", "minLength": 1 },
        "status_path": { "type": "string", "minLength": 1 },
        "exit_code": { "type": ["integer", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
