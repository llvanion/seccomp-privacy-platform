{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pipeline_slo_benchmark/v1",
  "title": "End-to-end pipeline latency SLO benchmark report",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "repo_root",
    "mode",
    "configuration",
    "expected_result",
    "command",
    "artifacts",
    "summary",
    "stages",
    "validation",
    "run"
  ],
  "properties": {
    "schema": {"const": "pipeline_slo_benchmark/v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "repo_root": {"type": "string", "minLength": 1},
    "mode": {"type": "string", "enum": ["file_handoff"]},
    "configuration": {
      "type": "object",
      "required": ["server_rows", "client_rows", "overlap_count", "campaign", "timeout_sec", "slo_targets_ms"],
      "properties": {
        "server_rows": {"type": "integer", "minimum": 1},
        "client_rows": {"type": "integer", "minimum": 1},
        "overlap_count": {"type": "integer", "minimum": 0},
        "campaign": {"type": "string", "minLength": 1},
        "timeout_sec": {"type": "number", "exclusiveMinimum": 0},
        "slo_targets_ms": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["p50", "p95"],
            "properties": {
              "p50": {"type": "number", "minimum": 0},
              "p95": {"type": "number", "minimum": 0}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "expected_result": {
      "type": "object",
      "required": ["intersection_size", "intersection_sum"],
      "properties": {
        "intersection_size": {"type": "integer", "minimum": 0},
        "intersection_sum": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "command": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "artifacts": {
      "type": "object",
      "required": ["out_base", "server_source", "client_source", "pipeline_observability"],
      "properties": {
        "out_base": {"type": "string", "minLength": 1},
        "server_source": {"type": "string", "minLength": 1},
        "client_source": {"type": "string", "minLength": 1},
        "pipeline_observability": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "status",
        "exit_code",
        "total_duration_ms",
        "total_pipeline",
        "stage_count",
        "missing_duration_stages",
        "slo_breach_stages",
        "all_stages_within_3x_p95"
      ],
      "properties": {
        "status": {"type": "string", "enum": ["ok", "fail"]},
        "exit_code": {"type": "integer"},
        "total_duration_ms": {"type": "number", "minimum": 0},
        "total_pipeline": {"$ref": "#/$defs/stage_result"},
        "stage_count": {"type": "integer", "minimum": 0},
        "missing_duration_stages": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "slo_breach_stages": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "all_stages_within_3x_p95": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "stages": {"type": "array", "items": {"$ref": "#/$defs/stage_result"}},
    "validation": {
      "type": "object",
      "required": [
        "intersection_size",
        "intersection_sum",
        "public_report_released",
        "public_report_reason_code",
        "mainline_contract_check_embedded"
      ],
      "properties": {
        "intersection_size": {"type": ["integer", "null"], "minimum": 0},
        "intersection_sum": {"type": ["integer", "null"], "minimum": 0},
        "public_report_released": {"type": ["boolean", "null"]},
        "public_report_reason_code": {"type": ["string", "null"]},
        "mainline_contract_check_embedded": {"type": ["boolean", "null"]}
      },
      "additionalProperties": false
    },
    "run": {
      "type": "object",
      "required": [
        "duration_ms",
        "exit_code",
        "timed_out",
        "stderr_tail",
        "stdout_tail",
        "observability_schema",
        "observability_event_count"
      ],
      "properties": {
        "duration_ms": {"type": "number", "minimum": 0},
        "exit_code": {"type": "integer"},
        "timed_out": {"type": "boolean"},
        "stderr_tail": {"type": "string"},
        "stdout_tail": {"type": "string"},
        "observability_schema": {"type": ["string", "null"]},
        "observability_event_count": {"type": ["integer", "null"], "minimum": 0}
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "stage_result": {
      "type": "object",
      "required": [
        "stage",
        "duration_ms",
        "p50_target_ms",
        "p95_target_ms",
        "within_p50_target",
        "within_p95_target",
        "within_3x_p95_target",
        "status"
      ],
      "properties": {
        "stage": {"type": "string", "minLength": 1},
        "duration_ms": {"type": ["number", "null"], "minimum": 0},
        "p50_target_ms": {"type": "number", "minimum": 0},
        "p95_target_ms": {"type": "number", "minimum": 0},
        "within_p50_target": {"type": ["boolean", "null"]},
        "within_p95_target": {"type": ["boolean", "null"]},
        "within_3x_p95_target": {"type": ["boolean", "null"]},
        "status": {"type": "string", "enum": ["ok", "missing_duration", "slo_breach"]}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
