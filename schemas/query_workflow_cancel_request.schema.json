{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "query_workflow_cancel_request/v1",
  "title": "Query workflow DB-backed cancellation request result",
  "type": "object",
  "required": ["schema", "job_id", "state", "terminal", "actor", "reason", "sidecar_written", "sidecar_status_path"],
  "properties": {
    "schema": { "const": "query_workflow_cancel_request/v1" },
    "job_id": { "type": "string", "minLength": 1 },
    "state": {
      "type": "string",
      "enum": ["cancel_requested", "cancelled"]
    },
    "terminal": { "type": "boolean" },
    "actor": { "type": ["string", "null"] },
    "reason": { "type": ["string", "null"] },
    "sidecar_written": { "type": "boolean" },
    "sidecar_status_path": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
