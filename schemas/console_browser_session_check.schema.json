{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "console_browser_session_check/v1",
  "title": "Operator console browser session smoke check",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "status",
    "checks",
    "finding_count",
    "findings"
  ],
  "properties": {
    "schema": { "const": "console_browser_session_check/v1" },
    "generated_at_utc": { "type": "string" },
    "status": { "enum": ["ok", "fail"] },
    "checks": {
      "type": "object",
      "properties": {
        "unauth_dashboard_status": { "type": "integer" },
        "login_status": { "type": "integer" },
        "set_cookie_contains_httponly": { "type": "boolean" },
        "set_cookie_contains_samesite_strict": { "type": "boolean" },
        "login_auth_source": { "type": ["string", "null"] },
        "cookie_names": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cookie_dashboard_status": { "type": "integer" },
        "cookie_dashboard_schema": { "type": ["string", "null"] },
        "session_status": { "type": "integer" },
        "session_auth_source": { "type": ["string", "null"] },
        "logout_status": { "type": "integer" },
        "logout_set_cookie": { "type": "string" }
      },
      "additionalProperties": true
    },
    "finding_count": { "type": "integer", "minimum": 0 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": { "type": "string" },
          "actual": {}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
