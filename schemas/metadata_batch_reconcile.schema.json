{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "metadata_batch_reconcile/v1",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "mode",
    "db_path",
    "summary",
    "issues",
    "repair_actions"
  ],
  "properties": {
    "schema": { "type": "string", "const": "metadata_batch_reconcile/v1" },
    "generated_at_utc": { "type": "string" },
    "mode": { "type": "string", "enum": ["dry_run", "repair"] },
    "db_path": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["job_count", "policy_count", "total_issues", "issue_counts", "repair_action_count", "status"],
      "properties": {
        "job_count": { "type": "integer", "minimum": 0 },
        "policy_count": { "type": "integer", "minimum": 0 },
        "total_issues": { "type": "integer", "minimum": 0 },
        "issue_counts": { "type": "object" },
        "repair_action_count": { "type": "integer", "minimum": 0 },
        "status": { "type": "string", "enum": ["ok", "issues_found"] }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check"],
        "properties": {
          "check": { "type": "string" }
        }
      }
    },
    "repair_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action", "applied"],
        "properties": {
          "action": { "type": "string" },
          "applied": { "type": "boolean" }
        }
      }
    }
  },
  "additionalProperties": false
}
