{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "console_security_headers_check/v1",
  "title": "Operator console security headers smoke check",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "status",
    "checks",
    "finding_count",
    "findings"
  ],
  "properties": {
    "schema": { "const": "console_security_headers_check/v1" },
    "generated_at_utc": { "type": "string" },
    "status": { "enum": ["ok", "fail"] },
    "checks": {
      "type": "object",
      "required": [
        "healthz",
        "dashboard_api",
        "spa_index",
        "spa_asset",
        "secure_cookie_hsts",
        "console_source"
      ],
      "properties": {
        "healthz": { "$ref": "#/$defs/header_check" },
        "dashboard_api": { "$ref": "#/$defs/header_check" },
        "spa_index": { "$ref": "#/$defs/header_check" },
        "spa_asset": { "$ref": "#/$defs/header_check" },
        "secure_cookie_hsts": {
          "type": "object",
          "properties": {
            "status": { "type": "integer" },
            "strict_transport_security": { "type": "string" }
          },
          "additionalProperties": true
        },
        "console_source": {
          "type": "object",
          "properties": {
            "checked_files": { "type": "integer", "minimum": 0 },
            "inline_style_finding_count": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "finding_count": { "type": "integer", "minimum": 0 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": { "type": "string" },
          "expected": {},
          "actual": {}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "header_check": {
      "type": "object",
      "properties": {
        "status": { "type": "integer" },
        "has_csp": { "type": "boolean" },
        "x_content_type_options": { "type": "string" },
        "x_frame_options": { "type": "string" },
        "referrer_policy": { "type": "string" },
        "permissions_policy": { "type": "string" },
        "csp_style_allows_inline": { "type": "boolean" },
        "csp_script_allows_inline": { "type": "boolean" },
        "csp_allows_unsafe_eval": { "type": "boolean" },
        "csp_connect_src": {
          "type": "array",
          "items": { "type": "string" }
        },
        "hsts_present": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  }
}
