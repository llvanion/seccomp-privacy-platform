{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "spiffe_envoy_peer_allowlist/v1",
  "title": "SPIFFE/SPIRE + Envoy peer allowlist",
  "type": "object",
  "required": ["schema", "trust_domain", "peers", "audit"],
  "properties": {
    "schema": { "const": "spiffe_envoy_peer_allowlist/v1" },
    "trust_domain": { "type": "string", "minLength": 1 },
    "peers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "spiffe_id", "allowed_peers", "svid_ttl_seconds", "rotation_window_seconds"],
        "properties": {
          "role": { "enum": ["server", "client"] },
          "spiffe_id": { "type": "string", "minLength": 9 },
          "allowed_peers": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 9 }
          },
          "svid_ttl_seconds": { "type": "integer", "minimum": 60, "maximum": 86400 },
          "rotation_window_seconds": { "type": "integer", "minimum": 30, "maximum": 86400 }
        },
        "additionalProperties": false
      }
    },
    "audit": {
      "type": "object",
      "required": ["destination", "include_fields"],
      "properties": {
        "destination": { "type": "string", "minLength": 1 },
        "include_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
