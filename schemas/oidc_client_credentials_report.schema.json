{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "oidc_client_credentials_report/v1",
  "title": "OIDC client credentials report",
  "type": "object",
  "required": ["schema", "generated_at_utc", "mode", "ok", "token_endpoint", "client_id"],
  "properties": {
    "schema": { "const": "oidc_client_credentials_report/v1" },
    "generated_at_utc": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["dry_run", "execute"] },
    "ok": { "type": "boolean" },
    "error": { "type": ["string", "null"] },
    "token_endpoint": { "type": "string", "minLength": 1 },
    "client_id": { "type": "string", "minLength": 1 },
    "scope": { "type": ["string", "null"] },
    "token_type": { "type": ["string", "null"] },
    "expires_in": { "type": ["integer", "null"], "minimum": 0 },
    "access_token_redacted": { "type": ["string", "null"] },
    "token_output_file": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
