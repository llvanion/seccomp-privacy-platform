{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "operator_dashboard_public_summary/v1",
  "title": "Caller-safe operator dashboard summary",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "authenticated_identity",
    "scope",
    "overall_status",
    "job",
    "workflow",
    "health",
    "artifacts",
    "redaction"
  ],
  "properties": {
    "schema": { "const": "operator_dashboard_public_summary/v1" },
    "generated_at_utc": { "type": ["string", "null"] },
    "authenticated_identity": {
      "type": ["object", "null"],
      "properties": {
        "caller": { "type": ["string", "null"] },
        "tenant_id": { "type": ["string", "null"] },
        "platform_roles": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "properties": {
        "job_id": { "type": ["string", "null"] },
        "correlation_id": { "type": ["string", "null"] },
        "caller": { "type": ["string", "null"] },
        "tenant_id": { "type": ["string", "null"] },
        "dataset_id": { "type": ["string", "null"] },
        "service_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "overall_status": { "type": ["string", "null"] },
    "job": {
      "type": "object",
      "required": ["state", "terminal", "last_updated_at_utc", "stage_statuses"],
      "properties": {
        "state": { "type": ["string", "null"] },
        "terminal": { "type": ["boolean", "null"] },
        "last_updated_at_utc": { "type": ["string", "null"] },
        "stage_statuses": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "status"],
            "properties": {
              "name": { "type": ["string", "null"] },
              "status": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "workflow": {
      "type": "object",
      "required": ["available", "state", "terminal", "recommended_action"],
      "properties": {
        "available": { "type": "boolean" },
        "state": { "type": ["string", "null"] },
        "terminal": { "type": ["boolean", "null"] },
        "recommended_action": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "health": {
      "type": "object",
      "properties": {
        "status": { "type": ["string", "null"] },
        "ok": { "type": ["integer", "null"] },
        "warn": { "type": ["integer", "null"] },
        "error": { "type": ["integer", "null"] }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "required": ["available_count", "total_count"],
      "properties": {
        "available_count": { "type": ["integer", "null"], "minimum": 0 },
        "total_count": { "type": ["integer", "null"], "minimum": 0 }
      },
      "additionalProperties": false
    },
    "redaction": {
      "type": "object",
      "required": [
        "operator_fields_redacted",
        "paths_redacted",
        "hashes_redacted",
        "exact_results_redacted"
      ],
      "properties": {
        "operator_fields_redacted": { "const": true },
        "paths_redacted": { "const": true },
        "hashes_redacted": { "const": true },
        "exact_results_redacted": { "const": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
