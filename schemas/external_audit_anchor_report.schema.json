{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "external_audit_anchor_report/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "generated_at_utc",
    "source_anchor_file",
    "external_sink",
    "mode",
    "summary",
    "records"
  ],
  "properties": {
    "schema": {
      "const": "external_audit_anchor_report/v1"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "source_anchor_file": {
      "type": "string"
    },
    "tenant_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "production_mode": {
      "type": "boolean"
    },
    "production_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "message"],
        "properties": {
          "kind": {
            "enum": [
              "production_file_ledger_not_external",
              "production_dry_run_not_allowed",
              "production_execute_required",
              "production_external_anchor_not_uploaded"
            ]
          },
          "message": { "type": "string", "minLength": 1 },
          "ref": { "type": ["string", "null"] }
        }
      }
    },
    "external_sink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path"
      ],
      "properties": {
        "kind": {
          "enum": [
            "file_ledger",
            "s3_worm",
            "rekor"
          ]
        },
        "path": {
          "type": "string"
        },
        "tenant_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "s3_object_lock": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "bucket",
            "key",
            "object_lock_mode",
            "retain_until_utc",
            "retain_days",
            "executed",
            "status"
          ],
          "properties": {
            "bucket": {
              "type": "string"
            },
            "key": {
              "type": "string"
            },
            "object_lock_mode": {
              "enum": [
                "COMPLIANCE",
                "GOVERNANCE"
              ]
            },
            "retain_until_utc": {
              "type": "string"
            },
            "retain_days": {
              "type": "integer",
              "minimum": 1
            },
            "executed": {
              "type": "boolean"
            },
            "status": {
              "enum": [
                "planned",
                "uploaded",
                "skipped",
                "error"
              ]
            },
            "details": {
              "type": [
                "string",
                "null"
              ]
            },
            "etag": {
              "type": [
                "string",
                "null"
              ]
            },
            "version_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "previous_object_etag": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "rekor_transparency_log": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "endpoint_url",
            "endpoint_path",
            "kind_version",
            "signature_algorithm",
            "executed",
            "status",
            "entries",
            "submitted_count",
            "uploaded_count"
          ],
          "properties": {
            "endpoint_url": {
              "type": "string"
            },
            "endpoint_path": {
              "type": "string"
            },
            "kind_version": {
              "type": "string"
            },
            "signature_algorithm": {
              "type": "string"
            },
            "executed": {
              "type": "boolean"
            },
            "status": {
              "enum": [
                "planned",
                "uploaded",
                "partial",
                "skipped",
                "error"
              ]
            },
            "details": {
              "type": [
                "string",
                "null"
              ]
            },
            "submitted_count": {
              "type": "integer",
              "minimum": 0
            },
            "uploaded_count": {
              "type": "integer",
              "minimum": 0
            },
            "entries": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "entry_sha256",
                  "payload_sha256",
                  "status"
                ],
                "properties": {
                  "entry_sha256": {
                    "type": "string"
                  },
                  "payload_sha256": {
                    "type": "string"
                  },
                  "uuid": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "log_index": {
                    "type": [
                      "integer",
                      "null"
                    ]
                  },
                  "integrated_time": {
                    "type": [
                      "integer",
                      "null"
                    ]
                  },
                  "status": {
                    "enum": [
                      "uploaded",
                      "error",
                      "skipped"
                    ]
                  },
                  "details": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "mode": {
      "enum": [
        "dry_run",
        "publish"
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "anchor_record_count",
        "published_count",
        "verified_chain",
        "signed_count",
        "last_entry_sha256"
      ],
      "properties": {
        "status": {
          "enum": [
            "ok",
            "fail"
          ]
        },
        "anchor_record_count": {
          "type": "integer",
          "minimum": 0
        },
        "published_count": {
          "type": "integer",
          "minimum": 0
        },
        "verified_chain": {
          "type": "boolean"
        },
        "signed_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_entry_sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "tenant_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "job_id",
          "chain_position",
          "entry_sha256",
          "payload_sha256",
          "index_record_sha256",
          "signature_algorithm",
          "signature_verified",
          "published"
        ],
        "properties": {
          "job_id": {
            "type": "string"
          },
          "chain_position": {
            "type": "integer",
            "minimum": 1
          },
          "entry_sha256": {
            "type": "string"
          },
          "payload_sha256": {
            "type": "string"
          },
          "index_record_sha256": {
            "type": "string"
          },
          "signature_algorithm": {
            "type": [
              "string",
              "null"
            ]
          },
          "signature_verified": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "tenant_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "published": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
