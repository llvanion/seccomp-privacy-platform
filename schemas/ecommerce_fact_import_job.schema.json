{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ecommerce_fact_import_job/v1",
  "title": "Validator-first e-commerce fact import job manifest/report",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "manifest_path",
    "status",
    "table",
    "input_path",
    "result_path",
    "command",
    "returncode"
  ],
  "properties": {
    "schema": { "const": "ecommerce_fact_import_job/v1" },
    "generated_at_utc": { "type": "string", "minLength": 1 },
    "manifest_path": { "type": "string", "minLength": 1 },
    "status": { "enum": ["ok", "fail"] },
    "table": { "type": "string", "minLength": 1 },
    "input_path": { "type": "string", "minLength": 1 },
    "result_path": { "type": "string", "minLength": 1 },
    "command": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "returncode": { "type": "integer" },
    "stdout": { "type": "string" },
    "stderr": { "type": "string" },
    "result": { "type": ["object", "null"] }
  },
  "additionalProperties": true
}
