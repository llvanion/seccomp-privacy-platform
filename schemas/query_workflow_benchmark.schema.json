{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "query_workflow_benchmark/v1",
  "title": "Benchmark report for query-workflow dry-run entrypoints",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "repo_root",
    "request_file",
    "iterations",
    "modes"
  ],
  "properties": {
    "schema": {
      "const": "query_workflow_benchmark/v1"
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    },
    "request_file": {
      "type": "string",
      "minLength": 1
    },
    "iterations": {
      "type": "integer",
      "minimum": 1
    },
    "modes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "mode",
          "command",
          "summary",
          "results"
        ],
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "cli_dry_run",
              "http_dry_run",
              "client_dry_run"
            ]
          },
          "command": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "summary": {
            "type": "object",
            "required": [
              "iterations",
              "successful_iterations",
              "failed_iterations",
              "duration_ms"
            ],
            "properties": {
              "iterations": {
                "type": "integer",
                "minimum": 0
              },
              "successful_iterations": {
                "type": "integer",
                "minimum": 0
              },
              "failed_iterations": {
                "type": "integer",
                "minimum": 0
              },
              "duration_ms": {
                "type": "object",
                "required": [
                  "min",
                  "mean",
                  "p50",
                  "p95",
                  "max"
                ],
                "properties": {
                  "min": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "mean": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "p50": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "p95": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "max": {
                    "type": [
                      "number",
                      "null"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "duration_ms",
                "exit_code",
                "timed_out",
                "stderr_tail"
              ],
              "properties": {
                "duration_ms": {
                  "type": "number",
                  "minimum": 0
                },
                "exit_code": {
                  "type": "integer"
                },
                "timed_out": {
                  "type": "boolean"
                },
                "stderr_tail": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "server_startup_ms": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
