{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ecommerce_fact_import_validation_smoke/v1",
  "title": "E-commerce fact import validation smoke report",
  "type": "object",
  "required": [
    "schema",
    "status",
    "allow_decision",
    "address_decision",
    "negative_value_decision",
    "support_transcript_decision"
  ],
  "properties": {
    "schema": { "const": "ecommerce_fact_import_validation_smoke/v1" },
    "status": { "const": "ok" },
    "allow_decision": { "const": "allow" },
    "address_decision": { "const": "deny" },
    "negative_value_decision": { "const": "deny" },
    "support_transcript_decision": { "const": "deny" }
  },
  "additionalProperties": false
}
