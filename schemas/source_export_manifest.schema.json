{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source_export_manifest/v1",
  "title": "Source snapshot and bridge-input export manifest",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "job_id",
    "caller",
    "tenant",
    "dataset",
    "purpose",
    "source_system",
    "source_snapshot_sha256",
    "bridge_input_sha256",
    "source_files",
    "bridge_input_files"
  ],
  "properties": {
    "schema": { "const": "source_export_manifest/v1" },
    "generated_at_utc": { "type": "string", "minLength": 1 },
    "job_id": { "type": "string", "minLength": 1 },
    "caller": { "type": "string", "minLength": 1 },
    "tenant": { "type": "string", "minLength": 1 },
    "dataset": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "source_system": { "type": "string", "minLength": 1 },
    "source_snapshot_sha256": { "type": "string", "minLength": 64 },
    "bridge_input_sha256": { "type": "string", "minLength": 64 },
    "source_files": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["label", "path", "sha256", "size_bytes"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "minLength": 64 },
          "size_bytes": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "bridge_input_files": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["label", "path", "sha256", "size_bytes"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "minLength": 64 },
          "size_bytes": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
