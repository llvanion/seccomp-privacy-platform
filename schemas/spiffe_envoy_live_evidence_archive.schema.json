{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "spiffe_envoy_live_evidence_archive/v1",
  "title": "SPIFFE/SPIRE + Envoy live evidence archive",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "status",
    "job_id",
    "templates_dir",
    "live_artifact_count",
    "live_artifacts",
    "findings",
    "artifacts",
    "aggregate_sha256"
  ],
  "properties": {
    "schema": { "const": "spiffe_envoy_live_evidence_archive/v1" },
    "generated_at_utc": { "type": "string", "minLength": 1 },
    "status": { "enum": ["ok", "fail"] },
    "job_id": { "type": "string", "minLength": 1 },
    "templates_dir": { "type": "string", "minLength": 1 },
    "live_artifact_count": { "type": "integer", "minimum": 0 },
    "live_artifacts": {
      "type": "object",
      "required": [
        "live_positive_run",
        "live_wrong_peer_reject",
        "live_expired_svid_reject",
        "live_trust_bundle_reject",
        "live_envoy_access_log"
      ],
      "properties": {
        "live_positive_run": {},
        "live_wrong_peer_reject": {},
        "live_expired_svid_reject": {},
        "live_trust_bundle_reject": {},
        "live_envoy_access_log": {}
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "size_bytes", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        },
        "additionalProperties": false
      }
    },
    "aggregate_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  },
  "additionalProperties": false
}
