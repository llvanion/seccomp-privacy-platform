{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mainline_contract_check/v1",
  "title": "Owner mainline contract consistency check result",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "repo_root",
    "out_base",
    "job_id",
    "status",
    "canonical_scope",
    "handoff_cleanup",
    "summary",
    "findings"
  ],
  "properties": {
    "schema": {
      "const": "mainline_contract_check/v1"
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "repo_root": {
      "type": "string"
    },
    "out_base": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "ok",
        "fail"
      ]
    },
    "canonical_scope": {
      "type": "object",
      "required": [
        "job_id",
        "correlation_id",
        "caller",
        "tenant_id",
        "dataset_id",
        "service_id",
        "token_scope",
        "token_key_version",
        "policy_version"
      ],
      "properties": {
        "job_id": {
          "type": "string"
        },
        "correlation_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "caller": {
          "type": [
            "string",
            "null"
          ]
        },
        "tenant_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "dataset_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "service_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "token_scope": {
          "type": [
            "string",
            "null"
          ]
        },
        "token_key_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "policy_version": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "handoff_cleanup": {
      "type": "object",
      "required": [
        "server",
        "client"
      ],
      "properties": {
        "server": {
          "$ref": "#/$defs/handoff_cleanup_entry"
        },
        "client": {
          "$ref": "#/$defs/handoff_cleanup_entry"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "checks_run",
        "error_count"
      ],
      "properties": {
        "checks_run": {
          "type": "integer",
          "minimum": 0
        },
        "error_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "kind",
          "path",
          "message",
          "expected",
          "actual"
        ],
        "properties": {
          "severity": {
            "const": "error"
          },
          "kind": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "expected": {},
          "actual": {}
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "handoff_cleanup_entry": {
      "type": "object",
      "required": [
        "role",
        "output_file",
        "output_file_type",
        "managed_by_out_base",
        "exists_after_run",
        "status"
      ],
      "properties": {
        "role": {
          "enum": [
            "server",
            "client"
          ]
        },
        "output_file": {
          "type": [
            "string",
            "null"
          ]
        },
        "output_file_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "managed_by_out_base": {
          "type": "boolean"
        },
        "exists_after_run": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "status": {
          "enum": [
            "cleaned",
            "missing_output_file",
            "not_applicable",
            "not_managed",
            "removed",
            "retained"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
