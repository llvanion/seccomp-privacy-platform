{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "issuer_credential_rotation/v1",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "issuer",
    "mode",
    "ok",
    "key_rotation_count",
    "key_rotations"
  ],
  "properties": {
    "schema": { "type": "string", "const": "issuer_credential_rotation/v1" },
    "generated_at_utc": { "type": "string" },
    "issuer": { "type": "string" },
    "issuer_type": { "type": ["string", "null"] },
    "service_id": { "type": ["string", "null"] },
    "mode": { "type": "string", "enum": ["dry_run", "apply"] },
    "ok": { "type": "boolean" },
    "error": { "type": ["string", "null"] },
    "key_rotation_count": { "type": "integer", "minimum": 0 },
    "key_rotations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key_name", "old_version", "new_version", "applied"],
        "properties": {
          "key_name": { "type": "string" },
          "old_version": { "type": "string" },
          "new_version": { "type": "string" },
          "applied": { "type": "boolean" }
        }
      }
    }
  },
  "additionalProperties": false
}
