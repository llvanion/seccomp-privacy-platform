{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pjc_two_party_negative_cases/v1",
  "title": "PJC two-party required negative-case summary",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "job_id",
    "decision",
    "reason_code",
    "required_cases",
    "cases"
  ],
  "properties": {
    "schema": { "const": "pjc_two_party_negative_cases/v1" },
    "generated_at_utc": { "type": "string", "format": "date-time" },
    "job_id": { "type": "string", "minLength": 1 },
    "decision": { "enum": ["allow", "deny"] },
    "reason_code": {
      "enum": [
        "ok",
        "missing_required_case",
        "unexpected_allow",
        "case_execution_failed",
        "config_error"
      ]
    },
    "reason": { "type": ["string", "null"] },
    "required_cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "wrong_token",
          "expired_token",
          "wrong_ca",
          "wrong_peer",
          "closed_port",
          "commit_mismatch",
          "modified_csv",
          "privacy_denial"
        ]
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "expected_decision", "actual_decision", "expected_reason_code", "actual_reason_code", "result"],
        "properties": {
          "name": {
            "enum": [
              "wrong_token",
              "expired_token",
              "wrong_ca",
              "wrong_peer",
              "closed_port",
              "commit_mismatch",
              "modified_csv",
              "privacy_denial"
            ]
          },
          "expected_decision": { "enum": ["allow", "deny"] },
          "actual_decision": { "enum": ["allow", "deny"] },
          "expected_reason_code": { "type": "string" },
          "actual_reason_code": { "type": "string" },
          "result": { "enum": ["pass", "fail", "skip"] },
          "message": { "type": ["string", "null"] },
          "evidence_path": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
