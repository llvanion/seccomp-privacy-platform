{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo_hygiene_scan/v1",
  "title": "Repository hygiene scan report",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "repo_root",
    "status",
    "summary",
    "findings"
  ],
  "properties": {
    "schema": {
      "const": "repo_hygiene_scan/v1"
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["ok", "warn", "error"]
    },
    "summary": {
      "type": "object",
      "required": ["error", "warn"],
      "properties": {
        "error": {
          "type": "integer",
          "minimum": 0
        },
        "warn": {
          "type": "integer",
          "minimum": 0
        },
        "tracked_files": {
          "type": "integer",
          "minimum": 0
        },
        "scanned_content_files": {
          "type": "integer",
          "minimum": 0
        },
        "truncated": {
          "type": "boolean"
        },
        "max_findings": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "kind"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["error", "warn"]
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": ["string", "null"]
          },
          "match": {
            "type": ["string", "null"]
          },
          "line": {
            "type": ["integer", "null"],
            "minimum": 1
          }
        }
      }
    }
  },
  "additionalProperties": false
}
