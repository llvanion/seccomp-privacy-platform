{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "metadata_api_health/v1",
  "title": "Health envelope for the metadata API",
  "type": "object",
  "required": [
    "schema",
    "ok",
    "db_path",
    "auth_required"
  ],
  "properties": {
    "schema": {
      "const": "metadata_api_health/v1"
    },
    "ok": {
      "type": "boolean"
    },
    "db_path": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "db_dsn": {
      "type": ["string", "null"]
    },
    "auth_required": {
      "type": "boolean"
    },
    "business_access_policy": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
