{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "platform_health_api_error/v1",
  "title": "Error envelope for the platform health API",
  "type": "object",
  "required": [
    "schema",
    "method",
    "path",
    "error"
  ],
  "properties": {
    "schema": {
      "const": "platform_health_api_error/v1"
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "error": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
