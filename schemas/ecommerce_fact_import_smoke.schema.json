{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ecommerce_fact_import_smoke/v1",
  "title": "Transactional e-commerce fact import smoke report",
  "type": "object",
  "required": [
    "schema",
    "status",
    "allow_decision",
    "allow_transaction",
    "sensitive_decision",
    "sensitive_transaction",
    "duplicate_decision",
    "duplicate_transaction",
    "final_order_count"
  ],
  "properties": {
    "schema": { "const": "ecommerce_fact_import_smoke/v1" },
    "status": { "const": "ok" },
    "allow_decision": { "const": "allow" },
    "allow_transaction": { "const": "committed" },
    "sensitive_decision": { "const": "deny" },
    "sensitive_transaction": { "const": "rejected_before_insert" },
    "duplicate_decision": { "const": "deny" },
    "duplicate_transaction": { "const": "rolled_back" },
    "delivery_legs_allow_decision": { "const": "allow" },
    "delivery_legs_sensitive_decision": { "const": "deny" },
    "order_attribution_allow_decision": { "const": "allow" },
    "order_payment_allow_decision": { "const": "allow" },
    "customer_service_allow_decision": { "const": "allow" },
    "final_delivery_leg_count": { "type": "integer", "minimum": 0 },
    "final_order_count": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
