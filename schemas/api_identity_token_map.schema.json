{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "api_identity_token_map/v1",
  "title": "Local API bearer token to caller identity mapping",
  "type": "object",
  "required": ["schema", "tokens"],
  "properties": {
    "schema": {
      "const": "api_identity_token_map/v1"
    },
    "tokens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["token_env", "issuer", "subject"],
        "properties": {
          "token_env": { "type": "string", "minLength": 1 },
          "issuer": { "type": "string" },
          "subject": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
