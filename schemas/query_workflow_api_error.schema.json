{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "query_workflow_api_error/v1",
  "title": "Error envelope for the local query/workflow HTTP adapter",
  "type": "object",
  "required": [
    "schema",
    "method",
    "path",
    "error"
  ],
  "properties": {
    "schema": {
      "const": "query_workflow_api_error/v1"
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "error_class": {
      "type": "string",
      "enum": [
        "authz_rejected",
        "endpoint_disabled",
        "internal_error",
        "not_found",
        "validation_rejected"
      ]
    },
    "error": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
