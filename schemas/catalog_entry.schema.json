{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "catalog_entry/v1",
  "title": "Privacy-safe catalog entry for datasets, jobs, and lineage",
  "description": "Records dataset metadata, schema versions, policy bindings, and job/artifact lineage. Never stores sensitive plaintext (join keys, secrets, raw identifiers).",
  "type": "object",
  "required": [
    "schema",
    "entry_type",
    "entry_id",
    "created_at_utc",
    "updated_at_utc"
  ],
  "properties": {
    "schema": {
      "const": "catalog_entry/v1"
    },
    "entry_type": {
      "enum": ["dataset", "schema_version", "policy_binding", "job", "artifact", "public_report"]
    },
    "entry_id": {
      "type": "string",
      "description": "Unique identifier for this catalog entry"
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant namespace"
    },
    "dataset": {
      "type": "object",
      "description": "Dataset-level metadata (entry_type=dataset)",
      "properties": {
        "dataset_id": { "type": "string" },
        "display_name": { "type": "string" },
        "description": { "type": "string" },
        "owner": { "type": "string" },
        "source_type": { "enum": ["jsonl", "csv", "encrypted_record_store"] },
        "record_count": { "type": "integer", "minimum": 0 },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field_name", "field_type"],
            "properties": {
              "field_name": { "type": "string" },
              "field_type": { "enum": ["join_key", "value", "filter", "metadata", "identifier"] },
              "normalizer": { "type": "string" },
              "is_sensitive": { "type": "boolean" }
            }
          }
        },
        "source_sha256": { "type": "string" },
        "current_schema_version": { "type": "string" }
      }
    },
    "schema_version_entry": {
      "type": "object",
      "description": "Schema version metadata (entry_type=schema_version)",
      "properties": {
        "version_id": { "type": "string" },
        "dataset_id": { "type": "string" },
        "version_number": { "type": "integer" },
        "fields_snapshot": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "field_name": { "type": "string" },
              "field_type": { "type": "string" }
            }
          }
        },
        "checksum": { "type": "string" },
        "backward_compatible": { "type": "boolean" }
      }
    },
    "policy_binding": {
      "type": "object",
      "description": "Policy-to-dataset binding (entry_type=policy_binding)",
      "properties": {
        "binding_id": { "type": "string" },
        "dataset_id": { "type": "string" },
        "policy_config_sha256": { "type": "string" },
        "policy_config_path": { "type": "string" },
        "allowed_roles": {
          "type": "array",
          "items": { "enum": ["server", "client"] }
        },
        "allowed_join_key_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowed_value_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_filters": {
          "type": "array",
          "items": { "type": "string" }
        },
        "min_export_rows": { "type": "integer" },
        "max_export_rows": { "type": "integer" },
        "bound_at_utc": { "type": "string", "format": "date-time" }
      }
    },
    "job": {
      "type": "object",
      "description": "Job-level metadata (entry_type=job)",
      "properties": {
        "job_id": { "type": "string" },
        "caller": { "type": "string" },
        "status": { "enum": ["pending", "running", "completed", "denied", "failed"] },
        "stages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "stage": { "type": "string" },
              "decision": { "type": "string" },
              "reason_code": { "type": "string" },
              "timestamp_utc": { "type": "string" }
            }
          }
        },
        "input_datasets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "output_artifacts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "started_at_utc": { "type": "string", "format": "date-time" },
        "completed_at_utc": { "type": "string", "format": "date-time" }
      }
    },
    "artifact": {
      "type": "object",
      "description": "Artifact metadata (entry_type=artifact)",
      "properties": {
        "artifact_id": { "type": "string" },
        "artifact_type": { "enum": ["sse_export", "bridge_output", "pjc_result", "public_report", "audit_chain", "audit_seal"] },
        "job_id": { "type": "string" },
        "stage": { "type": "string" },
        "file_path": { "type": "string" },
        "sha256": { "type": "string" },
        "size_bytes": { "type": "integer" },
        "row_count": { "type": "integer" },
        "generated_at_utc": { "type": "string", "format": "date-time" }
      }
    },
    "public_report_entry": {
      "type": "object",
      "description": "Public report lineage (entry_type=public_report)",
      "properties": {
        "report_id": { "type": "string" },
        "job_id": { "type": "string" },
        "released": { "type": "boolean" },
        "reason_code": { "type": "string" },
        "intersection_size": { "type": "integer" },
        "intersection_sum": { "type": "number" },
        "k_threshold": { "type": "integer" },
        "rate_limit_used": { "type": "integer" },
        "policy_version": { "type": "string" },
        "audit_chain_sha256": { "type": "string" }
      }
    },
    "lineage": {
      "type": "object",
      "description": "Lineage linking (written alongside entries, never stores sensitive values)",
      "properties": {
        "upstream_entries": {
          "type": "array",
          "items": { "type": "string" }
        },
        "downstream_entries": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
