# Logging and run directory
LOG_LEVEL=INFO
RUNS_ROOT=./runs

# A adapter (real pipeline)
A_PIPELINE_SCRIPT=
A_CRITEO_TSV=

# B adapter
# auto: try python_api then fallback local
# python_api: strict python API mode (requires B_SSE_ROOT and running B server)
# local: in-process local fallback index
B_BACKEND=auto
B_SSE_ROOT=
B_SERVER_URI=ws://127.0.0.1:8001
B_SCHEME=CJJ14.PiBas

# Rate limit
# auto: try redis then fallback memory
# redis: strict redis mode
# memory: in-process mode
RATE_LIMIT_BACKEND=auto
REDIS_URL=redis://127.0.0.1:6379/0
RATE_LIMIT_MAX_PER_ACTOR_ACTION=200
RATE_LIMIT_WINDOW_SECONDS=3600

# Audit
# sqlite | jsonl
AUDIT_BACKEND=sqlite
AUDIT_DB_PATH=./runs/gateway_audit.db
AUDIT_JSONL_PATH=./runs/gateway_audit.jsonl

# Capability token (W6)
TOKEN_SECRET=change-me-in-production
TOKEN_ISSUER=member-c-access-gateway
TOKEN_DEFAULT_EXPIRE_SECONDS=900
TOKEN_DB_PATH=./runs/gateway_tokens.db
TOKEN_JSONL_PATH=./runs/gateway_tokens.jsonl
