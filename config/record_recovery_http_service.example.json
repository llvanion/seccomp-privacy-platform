{
  "schema": "record_recovery_service_config/v1",
  "transport": "http",
  "service_id": "bridge-demo-recovery-http",
  "tenant_id": "demo_tenant",
  "dataset_id": "bridge_demo_dataset",
  "endpoint_url": "http://127.0.0.1:18081",
  "http_listener": {
    "bind_host": "127.0.0.1",
    "port": 18081
  },
  "auth_token_env": "SSE_RECORD_RECOVERY_TOKEN",
  "authz_config": "../sse/config/export_policy.example.json",
  "allowed_callers": [
    "auto_demo"
  ],
  "allowed_output_roots": [
    "/tmp"
  ],
  "allowed_record_store_roots": [
    "/tmp"
  ],
  "audit_log": "../tmp/record_recovery_service_http_audit.jsonl",
  "lifecycle": {
    "pid_file": "../tmp/record_recovery_service_http.pid",
    "ready_file": "../tmp/record_recovery_service_http.ready",
    "log_file": "../tmp/record_recovery_service_http.log"
  }
}
