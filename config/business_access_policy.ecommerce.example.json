{
  "schema": "business_access_policy/v1",
  "policy_id": "commerce-field-access-v1",
  "version": "2026-06-01",
  "default_decision": "deny",
  "roles": {
    "buyer": {
      "description": "Buyer self-service view for the buyer's own order only.",
      "allowed_entities": ["orders", "order_items", "order_fulfillment", "customer_service_interactions"],
      "allowed_field_classes": ["order_public", "item_public", "buyer_self_contact", "fulfillment_status", "support_status"],
      "masked_field_classes": [],
      "denied_field_classes": ["buyer_contact", "buyer_address", "merchant_internal", "courier_route_full", "support_internal", "operator_only"],
      "conditions": {
        "scope_required": true,
        "relationship_required": "self",
        "purpose_required": ["self_service", "support_case"]
      }
    },
    "merchant_staff": {
      "description": "Merchant staff can inspect order and item status, never buyer address/contact.",
      "allowed_entities": ["orders", "order_items", "order_fulfillment"],
      "allowed_field_classes": ["order_public", "item_public", "fulfillment_status"],
      "masked_field_classes": [],
      "denied_field_classes": ["buyer_contact", "buyer_address", "buyer_self_contact", "courier_next_stop", "courier_route_full", "support_internal", "operator_only"],
      "conditions": {
        "scope_required": true,
        "relationship_required": "merchant_of_order",
        "purpose_required": ["merchant_order_ops", "refund_review"]
      }
    },
    "customer_service_agent": {
      "description": "Support agents receive protected contact hints and support status, not raw addresses or full contact.",
      "allowed_entities": ["orders", "order_fulfillment", "customer_service_interactions"],
      "allowed_field_classes": ["order_public", "fulfillment_status", "support_status"],
      "masked_field_classes": ["buyer_contact"],
      "denied_field_classes": ["buyer_address", "buyer_self_contact", "merchant_internal", "courier_route_full", "operator_only"],
      "conditions": {
        "scope_required": true,
        "relationship_required": "assigned_support_case",
        "purpose_required": ["support_case", "refund_review"]
      }
    },
    "courier": {
      "description": "Courier receives only the fields for the currently assigned delivery leg, never the whole route or future-leg address details.",
      "allowed_entities": ["order_fulfillment", "delivery_route_legs"],
      "allowed_field_classes": ["courier_next_stop", "fulfillment_status", "courier_leg_meta"],
      "masked_field_classes": [],
      "denied_field_classes": ["order_public", "buyer_contact", "buyer_address", "buyer_self_contact", "merchant_internal", "courier_route_full", "courier_future_leg", "support_internal", "operator_only"],
      "conditions": {
        "scope_required": true,
        "relationship_required": "assigned_delivery_leg",
        "purpose_required": ["delivery_next_stop"]
      }
    },
    "station_operator": {
      "description": "Station operator can inspect the current station handoff leg and pickup-station logistics, but not final recipient address or unrelated legs.",
      "allowed_entities": ["order_fulfillment", "delivery_route_legs"],
      "allowed_field_classes": ["courier_next_stop", "fulfillment_status", "courier_leg_meta", "station_leg_handoff"],
      "masked_field_classes": [],
      "denied_field_classes": ["order_public", "buyer_contact", "buyer_address", "buyer_self_contact", "merchant_internal", "courier_route_full", "courier_future_leg", "support_internal", "operator_only"],
      "conditions": {
        "scope_required": true,
        "relationship_required": "assigned_station_leg",
        "purpose_required": ["station_handoff"]
      }
    },
    "last_mile_courier": {
      "description": "Last-mile courier can inspect the final delivery leg and the exact dropoff address required to complete delivery. Recipient phone is masked by default unless a call-proxy is used.",
      "allowed_entities": ["order_fulfillment", "delivery_route_legs"],
      "allowed_field_classes": ["courier_next_stop", "fulfillment_status", "courier_leg_meta", "last_mile_dropoff"],
      "masked_field_classes": ["last_mile_contact_masked"],
      "denied_field_classes": ["order_public", "buyer_contact", "buyer_address", "buyer_self_contact", "merchant_internal", "courier_route_full", "courier_future_leg", "support_internal", "operator_only"],
      "conditions": {
        "scope_required": true,
        "relationship_required": "assigned_last_mile_leg",
        "purpose_required": ["last_mile_delivery"]
      }
    },
    "field_marketer": {
      "description": "Field marketing users see campaign attribution aggregates, not buyer identity or logistics fields.",
      "allowed_entities": ["order_attribution"],
      "allowed_field_classes": ["campaign_public"],
      "masked_field_classes": [],
      "denied_field_classes": ["buyer_contact", "buyer_address", "buyer_self_contact", "merchant_internal", "courier_next_stop", "courier_route_full", "support_internal", "operator_only"],
      "conditions": {
        "scope_required": true,
        "relationship_required": "campaign_assignee",
        "purpose_required": ["campaign_analysis"]
      }
    },
    "fraud_analyst": {
      "description": "Fraud analysts can inspect payment risk/status signals without buyer contact, address, raw support, full route, or operator-only evidence.",
      "allowed_entities": ["orders", "order_payment"],
      "allowed_field_classes": ["order_public", "payment_status"],
      "masked_field_classes": [],
      "denied_field_classes": ["buyer_contact", "buyer_address", "buyer_self_contact", "merchant_internal", "courier_next_stop", "courier_route_full", "support_internal", "operator_only"],
      "conditions": {
        "scope_required": true,
        "relationship_required": "fraud_review_queue",
        "purpose_required": ["fraud_review"]
      }
    },
    "compliance_auditor": {
      "description": "Compliance auditors can inspect metadata and protected fields for audit purpose, with raw operator fields still separated.",
      "allowed_entities": ["orders", "order_items", "order_attribution", "order_payment", "order_fulfillment", "customer_service_interactions", "business_identities"],
      "allowed_field_classes": ["order_public", "item_public", "campaign_public", "payment_status", "fulfillment_status", "support_status", "merchant_internal"],
      "masked_field_classes": ["buyer_contact", "buyer_address"],
      "denied_field_classes": ["buyer_self_contact", "courier_route_full", "operator_only"],
      "conditions": {
        "scope_required": true,
        "relationship_required": "tenant_auditor",
        "purpose_required": ["compliance_audit"]
      }
    }
  },
  "field_classes": {
    "order_public": {
      "description": "Order data visible to non-sensitive business workflows.",
      "fields": ["orders.order_id", "orders.platform_id", "orders.campaign_id", "orders.currency", "orders.total_amount_cents", "orders.placed_at_utc", "orders.status"]
    },
    "item_public": {
      "description": "Line-item non-PII fields.",
      "fields": ["order_items.sku_id", "order_items.category_id", "order_items.quantity", "order_items.unit_price_cents", "order_items.line_total_cents"]
    },
    "campaign_public": {
      "description": "Campaign attribution fields without buyer identity.",
      "fields": ["order_attribution.attribution_type", "order_attribution.channel", "order_attribution.campaign_id", "order_attribution.creative_id", "order_attribution.attribution_weight"]
    },
    "payment_status": {
      "description": "Payment metadata without card/account identifiers.",
      "fields": ["order_payment.payment_method", "order_payment.provider_id", "order_payment.paid_amount_cents", "order_payment.paid_at_utc", "order_payment.risk_score", "order_payment.is_disputed"]
    },
    "buyer_contact": {
      "description": "Buyer contact information that must be masked for support workflows.",
      "fields": ["orders.buyer_email", "customer_profile.phone", "customer_profile.email"]
    },
    "buyer_self_contact": {
      "description": "Buyer contact visible only to the same buyer under self-service.",
      "fields": ["customer_profile.phone", "customer_profile.email"]
    },
    "buyer_address": {
      "description": "Buyer address and exact delivery destination.",
      "fields": ["customer_profile.address_line1", "customer_profile.address_line2", "customer_profile.city", "customer_profile.postal_code", "customer_profile.geo_hash", "order_fulfillment.delivery_address"]
    },
    "fulfillment_status": {
      "description": "Fulfillment state without route disclosure.",
      "fields": ["order_fulfillment.carrier_id", "order_fulfillment.warehouse_id", "order_fulfillment.shipped_at_utc", "order_fulfillment.delivered_at_utc", "order_fulfillment.status", "order_fulfillment.delivery_latency_minutes"]
    },
    "courier_leg_meta": {
      "description": "Metadata for the currently assigned leg, without exposing downstream recipient address.",
      "fields": ["delivery_route.leg_id", "delivery_route.route_id", "delivery_route.leg_sequence", "delivery_route.leg_kind", "delivery_route.assigned_courier_id", "delivery_route.assigned_station_id", "delivery_route.assigned_region_id", "delivery_route.origin_node_label", "delivery_route.destination_node_label", "delivery_route.destination_city", "delivery_route.status", "delivery_route.started_at_utc", "delivery_route.completed_at_utc"]
    },
    "courier_next_stop": {
      "description": "Only the next stop assigned to the courier, with the precise address exposed only on the terminal last-mile leg.",
      "fields": ["delivery_route.next_stop_label", "delivery_route.next_stop_window", "delivery_route.next_stop_geohash_prefix", "delivery_route.pickup_station_label", "delivery_route.pickup_station_geohash_prefix", "delivery_route.final_recipient_zone"]
    },
    "station_leg_handoff": {
      "description": "Station-specific handoff metadata for local pickup or handoff operators.",
      "fields": ["delivery_route.assigned_station_id", "delivery_route.destination_district", "delivery_route.pickup_station_label", "delivery_route.pickup_station_geohash_prefix"]
    },
    "last_mile_dropoff": {
      "description": "Exact destination fields needed only on the final delivery leg.",
      "fields": ["delivery_route.destination_district", "delivery_route.final_recipient_zone", "delivery_route.final_address_line1", "delivery_route.final_address_line2"]
    },
    "last_mile_contact_masked": {
      "description": "Recipient contact for final delivery is masked by default; a later live rollout can replace this with call-proxy evidence.",
      "fields": ["delivery_route.recipient_phone"]
    },
    "courier_future_leg": {
      "description": "Data from later or non-assigned legs that should not be visible to the current courier or station operator.",
      "fields": ["delivery_route.assigned_region_id", "delivery_route.destination_city", "delivery_route.final_address_token"]
    },
    "courier_route_full": {
      "description": "Full route and exact destination are not exposed to courier role by this policy.",
      "fields": ["delivery_route.full_route", "delivery_route.previous_stops", "delivery_route.final_address"]
    },
    "support_status": {
      "description": "Support ticket metadata without raw transcript.",
      "fields": ["customer_service_interactions.interaction_type", "customer_service_interactions.channel", "customer_service_interactions.agent_id", "customer_service_interactions.opened_at_utc", "customer_service_interactions.closed_at_utc", "customer_service_interactions.resolution_status"]
    },
    "support_internal": {
      "description": "Internal support notes and raw transcripts.",
      "fields": ["support_case.internal_notes", "support_case.raw_transcript", "support_case.escalation_reason"]
    },
    "merchant_internal": {
      "description": "Merchant-side operational notes.",
      "fields": ["merchant_profile.internal_rating", "merchant_profile.settlement_account_ref"]
    },
    "operator_only": {
      "description": "Platform operator-only fields, paths, hashes, and debug evidence.",
      "fields": ["audit.path", "audit.sha256", "audit.debug", "audit.raw_records", "policy.operator_report_path"]
    }
  },
  "protected_fields": {
    "orders.buyer_email": {
      "classification": "contact",
      "masking": "email_partial"
    },
    "customer_profile.email": {
      "classification": "contact",
      "masking": "email_partial"
    },
    "customer_profile.phone": {
      "classification": "contact",
      "masking": "phone_last4"
    },
    "customer_profile.address_line1": {
      "classification": "address",
      "masking": "redact"
    },
    "customer_profile.address_line2": {
      "classification": "address",
      "masking": "redact"
    },
    "customer_profile.city": {
      "classification": "address",
      "masking": "city_only"
    },
    "customer_profile.postal_code": {
      "classification": "address",
      "masking": "postal_prefix"
    },
    "customer_profile.geo_hash": {
      "classification": "location",
      "masking": "geohash_prefix"
    },
    "order_fulfillment.delivery_address": {
      "classification": "address",
      "masking": "redact"
    },
    "delivery_route.final_address": {
      "classification": "address",
      "masking": "redact"
    },
    "delivery_route.final_address_line1": {
      "classification": "address",
      "masking": "redact"
    },
    "delivery_route.final_address_line2": {
      "classification": "address",
      "masking": "redact"
    },
    "delivery_route.recipient_phone": {
      "classification": "contact",
      "masking": "phone_last4"
    },
    "delivery_route.final_address_token": {
      "classification": "address_token",
      "masking": "redact"
    },
    "delivery_route.final_recipient_zone": {
      "classification": "delivery_zone",
      "masking": "district_only"
    },
    "delivery_route.destination_district": {
      "classification": "district",
      "masking": "district_only"
    },
    "support_case.raw_transcript": {
      "classification": "support_transcript",
      "masking": "redact"
    },
    "support_case.internal_notes": {
      "classification": "internal_note",
      "masking": "redact"
    }
  }
}
